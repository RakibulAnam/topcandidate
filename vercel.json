{
  "framework": "vite",
  "buildCommand": "vite build",
  "devCommand": "vite --port $PORT",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/((?!api/|@|src/|node_modules/|assets/|.*\\.).*)", "destination": "/index.html" }
  ]
}
