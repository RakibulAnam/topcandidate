# ──────────────────────────────────────────────────────────────────
# Vercel environment variables — split into client and server scope
# ──────────────────────────────────────────────────────────────────
# IMPORTANT: keys WITHOUT the VITE_ prefix stay server-only (Vercel
# Functions in /api/*). Keys WITH the VITE_ prefix are baked into the
# client bundle and visible to anyone who opens DevTools.
#
# AI provider keys (Groq + Gemini) MUST stay non-VITE_ — they're sensitive.
# Supabase URL + anon key are PUBLIC by design and need VITE_ to reach the
# browser client. The anon key only allows operations within RLS policies.

# ──────────────────────────────────────────────
# AI providers (server-only — used by /api/*)
# ──────────────────────────────────────────────
# Groq — primary optimizer. Free tier: 1,000 RPD on llama-3.3-70b-versatile.
# Get a key (free) at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Gemini — fallback optimizer + all toolkit generators (cover letter, etc.)
# Free tier: 20 RPD on gemini-2.5-flash. Get a key at:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ──────────────────────────────────────────────
# Supabase (public — both client and server use these)
# ──────────────────────────────────────────────
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ──────────────────────────────────────────────
# Supabase service role (server-only — used by /api/confirm-purchase)
# ──────────────────────────────────────────────
# The service-role key bypasses RLS. We use it ONLY in the bKash purchase
# confirmation webhook, which is gated by an HMAC signature from the owner's
# Flutter SMS-watcher app (see BKASH_WEBHOOK_SECRET below). NEVER expose
# this key to the client; never prefix it with VITE_.
# Get it from Supabase Dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ──────────────────────────────────────────────
# bKash payment flow (no traditional gateway)
# ──────────────────────────────────────────────
# Owner's bKash number — shown to users in the PurchaseModal as the
# destination for Send Money / Make Payment. This one is VITE_ prefixed
# because it's intended to be visible (it's where customers send money to).
VITE_BKASH_PAYMENT_NUMBER=01XXXXXXXXX

# Shared secret between this server and the owner's Flutter SMS-watcher
# app. The Flutter app HMAC-SHA256-signs each /api/confirm-purchase request
# body with this secret; we verify with timing-safe compare. Generate a
# new random 32-byte hex string (e.g., `openssl rand -hex 32`) and put
# the same value in the Flutter app's secrets.
BKASH_WEBHOOK_SECRET=generate_a_random_32_byte_hex_string

# ──────────────────────────────────────────────
# Mock auto-confirm — DEV ONLY, REMOVE BEFORE PROD SHIP
# ──────────────────────────────────────────────
# When VITE_BKASH_MOCK_AUTOCONFIRM=true, the PurchaseModal automatically
# calls /api/dev-mock-confirm a few seconds after a pending purchase is
# submitted, so the buy → pending → credits-arrive flow can be tested
# end-to-end without the Flutter SMS-watcher being built yet. Both flags
# must be true for the mock path to do anything; in production set them
# to false (or unset) AND delete api/dev-mock-confirm.ts entirely.
VITE_BKASH_MOCK_AUTOCONFIRM=true
BKASH_MOCK_AUTOCONFIRM=true
