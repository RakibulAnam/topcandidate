# ──────────────────────────────────────────────────────────────────
# Vercel environment variables — split into client and server scope
# ──────────────────────────────────────────────────────────────────
# IMPORTANT: keys WITHOUT the VITE_ prefix stay server-only (Vercel
# Functions in /api/*). Keys WITH the VITE_ prefix are baked into the
# client bundle and visible to anyone who opens DevTools.
#
# AI provider keys (OpenRouter, or legacy Groq + Gemini) MUST stay non-VITE_ — they're sensitive.
# Supabase URL + anon key are PUBLIC by design and need VITE_ to reach the
# browser client. The anon key only allows operations within RLS policies.

# ──────────────────────────────────────────────
# AI provider (server-only — used by /api/*)
# ──────────────────────────────────────────────
# OpenRouter — PRIMARY provider (single key fronts all models). When set, ALL AI
# runs through OpenRouter: DeepSeek V3.2 optimizer → Gemini 2.5 Flash toolkit /
# single-artifact → Gemini 2.5 Flash-Lite extractor, each with a fallback chain.
# `api/_lib/aiFactory.ts` gates on this key. SET A HARD MONTHLY SPEND CAP on the
# key in the OpenRouter dashboard, and enable ZDR routing (resumes are PII).
# Get a key at: https://openrouter.ai/keys   — see docs/OPENROUTER_MIGRATION.md
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Legacy fallback (Groq + Gemini direct) ──
# Used ONLY when OPENROUTER_API_KEY is ABSENT. Kept one release cycle as the
# rollback / panic switch; a follow-up (migration Phase 6b) removes them.
# Groq — legacy primary optimizer. Free tier: 1,000 RPD on llama-3.3-70b-versatile.
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# Gemini — legacy fallback optimizer + all legacy toolkit/extractor generators.
# Free tier: 20 RPD on gemini-2.5-flash. https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ──────────────────────────────────────────────
# Supabase (public — both client and server use these)
# ──────────────────────────────────────────────
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ──────────────────────────────────────────────
# Supabase service role (server-only — used by /api/confirm-purchase)
# ──────────────────────────────────────────────
# The service-role key bypasses RLS. We use it ONLY in the bKash purchase
# confirmation webhook, which is gated by an HMAC signature from the owner's
# Flutter SMS-watcher app (see BKASH_WEBHOOK_SECRET below). NEVER expose
# this key to the client; never prefix it with VITE_.
# Get it from Supabase Dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ──────────────────────────────────────────────
# bKash payment flow (no traditional gateway)
# ──────────────────────────────────────────────
# Owner's bKash number — shown to users in the PurchaseModal as the
# destination for Send Money / Make Payment. This one is VITE_ prefixed
# because it's intended to be visible (it's where customers send money to).
VITE_BKASH_PAYMENT_NUMBER=01XXXXXXXXX

# Shared secret between this server and the owner's Flutter SMS-watcher
# app. The Flutter app HMAC-SHA256-signs each /api/confirm-purchase request
# body with this secret; we verify with timing-safe compare. Generate a
# new random 32-byte hex string (e.g., `openssl rand -hex 32`) and put
# the same value in the Flutter app's secrets.
BKASH_WEBHOOK_SECRET=generate_a_random_32_byte_hex_string

# ──────────────────────────────────────────────
# Admin panel — owner login (server-only)
# ──────────────────────────────────────────────
# The /admin SPA uses a username + password login (POST /api/admin/login).
# On success the server mints a short-lived signed session token that the SPA
# keeps in sessionStorage — so closing the tab logs you out. Owner-only; no
# roles. See api/admin/_lib/session.ts.
#
# ADMIN_API_KEY is REPURPOSED: it is no longer pasted anywhere. It is now the
# HMAC secret used to sign/verify session tokens. Must be long + random.
# Rotating it invalidates all live sessions. Generate: `openssl rand -hex 32`.
ADMIN_API_KEY=generate_a_random_32_byte_hex_string

# The owner's login username.
ADMIN_USERNAME=owner

# The owner's password, as an scrypt hash in the form "<saltHex>:<keyHex>".
# Generate (replace YOUR_PASSWORD):
#   node -e "const c=require('crypto');const s=c.randomBytes(16).toString('hex');console.log(s+':'+c.scryptSync('YOUR_PASSWORD',Buffer.from(s,'hex'),64).toString('hex'))"
# Easier (less safe) alternative: skip the hash and set ADMIN_PASSWORD=plaintext.
# If ADMIN_PASSWORD_HASH is set it takes precedence over ADMIN_PASSWORD.
ADMIN_PASSWORD_HASH=saltHex:keyHex
# ADMIN_PASSWORD=your_plaintext_password   # fallback if no hash is set

# /api/cron/expire-pending flips pending purchases > 24h old to 'expired'.
# It authenticates via this secret as `Authorization: Bearer <CRON_SECRET>`.
# Generate with: `openssl rand -hex 32`.
# NOTE: vercel.json defines no `crons` block, so Vercel does NOT schedule this
# job in this repo. Run it on a schedule via Supabase pg_cron
# (supabase/migrations/007_optional_pg_cron.sql) or trigger it manually from the
# admin Settings tab. To use Vercel Cron instead, add a `crons` entry to
# vercel.json (note: Vercel Hobby allows only one run/day).
CRON_SECRET=generate_a_random_32_byte_hex_string
